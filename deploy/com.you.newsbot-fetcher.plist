<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.you.newsbot-fetcher</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/gurdeepsingh/Desktop/learning/news-claw/.venv/bin/python</string>
    <string>-m</string>
    <string>fetcher.fetch</string>
  </array>

  <key>WorkingDirectory</key>
